{
  "version": "v1",
  "hooks": [
    {
      "name": "Validación de Steps de Test",
      "trigger": "PreToolUse",
      "description": "Validar YAML de workflows tenga step de tests",
      "matcher": "fs_write|str_replace|fs_append",
      "action": {
        "type": "command",
        "command": "node validate-workflow.js"
      },
      "timeout": 30
    }
  ]
}